{
  "schema_version": 1,
  "name": "RSI with volume confluence (test fixture)",
  "direction": "long_only",
  "entry": {
    "groups": [
      {
        "direction": "long",
        "conditions": [
          {
            "type": "rsi_threshold",
            "params": { "period": 14, "comparator": "lt", "value": 30 }
          },
          {
            "type": "volume_ratio",
            "params": { "period": 20, "comparator": "gte", "multiple": 1.5 }
          },
          {
            "type": "sma_position",
            "params": { "period": 50, "position": "above" }
          }
        ]
      }
    ]
  },
  "exit": {
    "stop": { "type": "atr_multiple", "period": 14, "multiple": 1.5 },
    "target": { "type": "fixed_rr", "rr": 2.0 }
  },
  "sizing": {
    "type": "fixed_gbp_risk",
    "amount": 30
  }
}
